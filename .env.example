# ─────────────────────────────────────────────────────────────────────────────
#  Recipe Delivery Platform — Environment Variables Template
#
#  SETUP:
#    1. cp .env.example .env
#    2. Fill in every value marked  ← CHANGE THIS
#    3. NEVER commit .env to git — it is already in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ChangeMe123!         # ← CHANGE THIS

# ── API Gateway — JWT ─────────────────────────────────────────────────────────
# Must be exactly 64 hex characters (256-bit).
# Generate:  openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars_from_openssl_rand_hex_32    # ← CHANGE THIS

# ── Notification Service — Gmail SMTP ─────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google Account
# 2. Google Account → Security → App Passwords → create one for "Mail"
# 3. Paste the 16-character code (no spaces) as MAIL_PASSWORD
MAIL_USERNAME=your_email@gmail.com          # ← CHANGE THIS
MAIL_PASSWORD=abcd efgh ijkl mnop           # ← CHANGE THIS (paste 16-char App Password)
MAIL_FROM=RasoiKit <your_email@gmail.com>   # ← CHANGE THIS

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin               # ← CHANGE THIS in production

# ── Frontend (React) ─────────────────────────────────────────────────────────
# Keep as-is for docker-compose local dev.
# For production, set to your public domain: https://api.yourdomain.com
REACT_APP_API_URL=http://localhost:8080
